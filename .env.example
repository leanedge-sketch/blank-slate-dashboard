# Copy to .env for local development (never commit .env)

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# OpenAI (primary gpt-4o + secondary gpt-4o-mini chat fallback)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_CHAT_MODEL=gpt-4o-mini
MODEL_CHOICE=gpt-4o

# Gemini (tertiary chat fallback — also set GEMINI_API_KEY on Vercel)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_CHAT_MODEL=gemini-2.5-flash

# Frontend (optional for local Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# Telegram CRM notifications (same bot as imported history)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
NOTIFICATION_ENABLED=true

# Email (optional — password change verification)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=LeanChem Connect <noreply@yourdomain.com>

# --- Frontend (Vite build) — optional if server vars below are set on Vercel ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# --- Backend (Vercel serverless /api) — REQUIRED for production ---
# Copy values from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Email for password-change verification (use Resend or SMTP)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=LeanChem Connect <noreply@yourdomain.com>
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Production app URL (auth redirects, magic links)
VITE_FRONTEND_URL=https://blank-slate-dashboard-plum.vercel.app

# Leave VITE_API_URL unset in production — the app uses Vercel /api/v1 on *.vercel.app.
# Do not point at Render (*.onrender.com).

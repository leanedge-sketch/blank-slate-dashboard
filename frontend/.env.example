# --- Frontend (Vite build) — optional if server vars below are set on Vercel ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-key

# --- Backend (Vercel serverless /api) — REQUIRED for production ---
# Copy values from Supabase Dashboard → Settings → API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Email for password-change verification (required for Change password in Profile menu)
# RESEND_API_KEY=re_xxxx
# EMAIL_FROM=LeanChem Connect <noreply@yourdomain.com>
# Or SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASSWORD, EMAIL_FROM
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=

# Gemini is configured on the backend only (GEMINI_API_KEY in Vercel / root .env).

# Telegram — outbound CRM notifications (backend only, same bot as legacy CRM)
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=-1001234567890
# NOTIFICATION_ENABLED=true

# Local dev only (optional). Production builds always use plum — do not rely on this on Vercel.
# VITE_FRONTEND_URL=http://localhost:5173

# Local dev: optional backend URL (defaults to http://localhost:8000/api/v1)
# VITE_API_URL=http://localhost:8000/api/v1

# Leave VITE_API_URL unset in production — the app uses Vercel /api/v1 on *.vercel.app.
# Do not point at Render (*.onrender.com).
